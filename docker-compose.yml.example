services:
  resinx:
    build:
      context: .
      dockerfile: Dockerfile
    image: ghcr.io/resinat/resinx:latest
    container_name: resinx
    restart: unless-stopped
    environment:
      RESIN_AUTH_VERSION: ${RESIN_AUTH_VERSION}
      RESIN_ADMIN_TOKEN: ${RESIN_ADMIN_TOKEN}
      RESIN_PROXY_TOKEN: ${RESIN_PROXY_TOKEN}
      RESIN_LISTEN_ADDRESS: 0.0.0.0
      RESIN_PORT: 2260
      # TZ: <Your Time Zone>
    ports:
      - "2260:2260"
    volumes:
      - resinx_cache:/var/cache/resin
      - resinx_state:/var/lib/resin
      - resinx_log:/var/log/resin
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:2260/healthz >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s

volumes:
  resinx_cache:
  resinx_state:
  resinx_log:
